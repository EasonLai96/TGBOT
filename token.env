# 將此檔案複製為 token.env,並填入你自己的Token
# 切記:token.env 絕對不要上傳到GitHub,務必加進 .gitignore

# Telegram Bot Token,取得方式:
# 1. Telegram搜尋 @BotFather
# 2. 輸入 /newbot,依指示設定名稱
# 3. 把BotFather回覆的token貼在下面
TELEGRAM_BOT_TOKEN=8801787920:AAHLxTAC0MrVJCnaJ1uXyYAa3qwpeCgcRQA

# Pixiv refresh token,取得方式:
# 1. pip install gppt
# 2. gppt login (用你的Pixiv帳號登入一次)
# 3. 把印出來的 refresh_token 貼在下面
PIXIV_REFRESH_TOKEN=xhBMsiJ667r0A37SKk-IGIP5i_nq6a3bU0Yo_u-fSFM
